<!--search.wxml-->
<navigation-bar title="搜索食物" back="{{true}}" color="black" background="#FFF"></navigation-bar>

<view class="container">
  <!-- 搜索框 -->
  <view class="search-header">
    <view class="search-box">
      <image src="../../static/search-icon.png" class="search-icon"></image>
      <input 
        class="search-input"
        type="text"
        placeholder="搜索食物名称"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        focus="{{true}}"
      />
      <view 
        class="clear-btn {{searchKeyword ? 'show' : ''}}"
        bindtap="clearSearch"
      >
        ✕
      </view>
    </view>
    
    <view 
      class="search-btn {{searchKeyword ? 'active' : ''}}"
      bindtap="performSearch"
    >
      搜索
    </view>
  </view>

  <!-- 快速筛选 -->
  <view class="filter-section" wx:if="{{!searchKeyword}}">
    <scroll-view class="filter-scroll" scroll-x="true">
      <view class="filter-tags">
        <view 
          class="filter-tag {{selectedCategory === item.key ? 'active' : ''}}"
          wx:for="{{foodCategories}}"
          wx:key="key"
          data-category="{{item.key}}"
          bindtap="selectCategory"
        >
          <text class="tag-icon">{{item.icon}}</text>
          <text class="tag-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <scroll-view class="content-scroll" scroll-y="true">
    <!-- 搜索历史 -->
    <view class="history-section" wx:if="{{!searchKeyword && searchHistory.length > 0}}">
      <view class="section-header">
        <text class="section-title">搜索历史</text>
        <text class="clear-history" bindtap="clearHistory">清除</text>
      </view>
      
      <view class="history-tags">
        <view 
          class="history-tag"
          wx:for="{{searchHistory}}"
          wx:key="*this"
          data-keyword="{{item}}"
          bindtap="selectHistoryKeyword"
        >
          {{item}}
        </view>
      </view>
    </view>

    <!-- 热门搜索 -->
    <view class="hot-section" wx:if="{{!searchKeyword}}">
      <view class="section-header">
        <text class="section-title">热门搜索</text>
      </view>
      
      <view class="hot-tags">
        <view 
          class="hot-tag"
          wx:for="{{hotKeywords}}"
          wx:key="*this"
          data-keyword="{{item}}"
          bindtap="selectHotKeyword"
        >
          {{item}}
        </view>
      </view>
    </view>

    <!-- 常用食物 -->
    <view class="common-section" wx:if="{{!searchKeyword && !searchResults.length}}">
      <view class="section-header">
        <text class="section-title">常用食物</text>
      </view>
      
      <view class="food-grid">
        <view 
          class="food-card"
          wx:for="{{commonFoods}}"
          wx:key="id"
          data-food="{{item}}"
          bindtap="selectFood"
        >
          <image src="{{item.image}}" class="food-image"></image>
          <text class="food-name">{{item.name}}</text>
          <text class="food-calories">{{item.calories}}千卡/100g</text>
        </view>
      </view>
    </view>

    <!-- 搜索结果 -->
    <view class="results-section" wx:if="{{searchResults.length > 0}}">
      <view class="section-header">
        <text class="section-title">搜索结果 ({{searchResults.length}})</text>
      </view>
      
      <view class="results-list">
        <view 
          class="result-item"
          wx:for="{{searchResults}}"
          wx:key="id"
          data-food="{{item}}"
          bindtap="selectFood"
        >
          <image src="{{item.image}}" class="result-image"></image>
          
          <view class="result-info">
            <text class="result-name">{{item.name}}</text>
            <text class="result-desc">{{item.description}}</text>
            
            <view class="nutrition-info">
              <text class="nutrition-item">热量 {{item.calories}}千卡</text>
              <text class="nutrition-item">蛋白质 {{item.protein}}g</text>
              <text class="nutrition-item">脂肪 {{item.fat}}g</text>
              <text class="nutrition-item">碳水 {{item.carbs}}g</text>
            </view>
          </view>
          
          <view class="result-action">
            <text class="add-btn">添加</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 搜索为空状态 -->
    <view class="empty-state" wx:if="{{searchKeyword && searchResults.length === 0 && !isSearching}}">
      <image src="../../static/empty-search.png" class="empty-icon"></image>
      <text class="empty-text">没有找到相关食物</text>
      <text class="empty-tip">试试其他关键词或使用拍照识别功能</text>
      
      <button class="goto-camera-btn" bindtap="gotoCamera">
        拍照识别
      </button>
    </view>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{isSearching}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">搜索中...</text>
    </view>
  </scroll-view>

  <!-- 食物详情弹窗 -->
  <view class="food-detail-modal {{showFoodDetail ? 'show' : ''}}" bindtap="hideFoodDetail">
    <view class="modal-content" catchtap="stopPropagation" wx:if="{{selectedFood}}">
      <view class="modal-header">
        <text class="modal-title">{{selectedFood.name}}</text>
        <text class="modal-close" bindtap="hideFoodDetail">✕</text>
      </view>
      
      <view class="food-detail-content">
        <image src="{{selectedFood.image}}" class="detail-image"></image>
        
        <view class="detail-form">
          <view class="form-row">
            <text class="form-label">重量</text>
            <view class="input-group">
              <input 
                type="digit"
                class="weight-input"
                value="{{foodWeight}}"
                bindinput="onWeightInput"
                placeholder="100"
              />
              <text class="input-unit">g</text>
            </view>
          </view>
          
          <view class="form-row">
            <text class="form-label">餐次</text>
            <picker 
              mode="selector"
              range="{{mealTypes}}"
              value="{{selectedMealIndex}}"
              bindchange="onMealChange"
            >
              <view class="picker-display">{{mealTypes[selectedMealIndex]}}</view>
            </picker>
          </view>
        </view>
        
        <view class="nutrition-summary">
          <view class="summary-item">
            <text class="summary-label">热量</text>
            <text class="summary-value">{{calculatedNutrition.calories}}千卡</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">蛋白质</text>
            <text class="summary-value">{{calculatedNutrition.protein}}g</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">脂肪</text>
            <text class="summary-value">{{calculatedNutrition.fat}}g</text>
          </view>
          <view class="summary-item">
            <text class="summary-label">碳水</text>
            <text class="summary-value">{{calculatedNutrition.carbs}}g</text>
          </view>
        </view>
        
        <button class="add-record-btn" bindtap="addFoodRecord">
          添加到记录
        </button>
      </view>
    </view>
  </view>
</view>